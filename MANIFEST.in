# Include the README
include *.md

# Include requirements
include requirements.txt

# Include the license file
include LICENSE

# Include the data files
recursive-include scripts *

# Include services files
recursive-include services *.service

# Include package tests
recursive-include rtop/tests *.py

# Remove test docs and examples and tox.ini
exclude tox.ini
exclude Dockerfile
exclude .dockerignore
prune docs
prune examples

# IMPORTANT: exclude pyproject.toml from the sdist.
# With pyproject.toml present, pip treats the package as PEP 517 and skips
# our setup.py `install` command — which is exactly where we auto-install
# the systemd service. Omitting it from the sdist forces legacy setup.py
# mode at install time, matching what jetson_stats ships on PyPI.
exclude pyproject.toml
